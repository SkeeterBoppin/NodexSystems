{
  "version": 1,
  "formulas": [
    {
      "id": "kinetic_energy",
      "domain": "physics.mechanics",
      "name": "Kinetic Energy",
      "description": "KE = 0.5 * mass * velocity^2",
      "variables": {
        "mass": {
          "type": "number",
          "required": true,
          "quantity": "mass"
        },
        "velocity": {
          "type": "number",
          "required": true,
          "quantity": "speed"
        }
      },
      "output": {
        "type": "number",
        "quantity": "energy"
      },
      "expression": {
        "op": "multiply",
        "args": [
          0.5,
          {
            "var": "mass"
          },
          {
            "op": "power",
            "args": [
              {
                "var": "velocity"
              },
              2
            ]
          }
        ]
      }
    },
    {
